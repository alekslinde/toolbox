---
import MainLayout from '@/layouts/MainLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import QuickTips from '@/components/QuickTips.astro';
import FAQAccordion from '@/components/FAQAccordion.astro';

const tips = [
  { heading: 'Contain', body: 'Scales to fit inside the target box, keeping aspect ratio. Edges stay transparent.' },
  { heading: 'Cover',   body: 'Scales to fill the box, cropping the overflow on both axes.' },
  { heading: 'Stretch', body: 'Distorts image to fill width × height exactly — ignores aspect ratio.' },
  { heading: 'Pad',     body: 'Like Contain, but fills the empty areas with a solid colour you choose.' },
];

const cheatSheet = [
  { label: 'JPEG', value: 'Photos, no transparency' },
  { label: 'PNG',  value: 'Graphics, transparency' },
  { label: 'WebP', value: 'Best web compression' },
];

const faq = [
  { question: 'Does resizing upload my image?', answer: 'No. Everything runs in your browser using the Canvas API. Your file never leaves your device.' },
  { question: 'What fit modes are available?', answer: 'Contain (letterbox), Cover (crop and fill), Stretch (distort to exact size), and Pad (letterbox with a solid fill colour).' },
  { question: 'Will locking aspect ratio change my target dimensions?', answer: 'Yes — when the lock is on, changing width recalculates height and vice versa, preserving the original aspect ratio.' },
];
---

<MainLayout
  title="Image Resizer — Free In-Browser Tool | Toolbox"
  description="Resize images to exact pixel dimensions in your browser. Contain, cover, stretch or pad fit modes. PNG, JPEG and WebP output. No uploads."
  alpine={true}
>
  <div class="px-8 py-10 lg:px-8 max-w-[1440px] mx-auto" x-data="imageResizer">

    <div class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
      <div>
        <Breadcrumbs tool="Image Resizer" category="Images & Documents" />
        <h1 class="mt-3 text-2xl font-semibold tracking-tight text-slate-900">Image Resizer</h1>
        <p class="mt-1 text-sm text-slate-500">Resize to exact dimensions. Contain · Cover · Stretch · Pad.</p>
      </div>
      <button
        class="flex shrink-0 items-center gap-2 self-start rounded-full border border-slate-200 bg-white px-4 py-2 text-sm text-slate-500 shadow-sm transition-all hover:border-purple-200 hover:text-purple-600"
        @click="helpful++"
        :class="helpful > 0 ? 'border-purple-300 bg-purple-50 text-purple-600' : ''"
      >
        <span>👍</span><span>This helped me</span>
        <span x-show="helpful > 0" class="font-semibold text-purple-600" x-text="helpful"></span>
      </button>
    </div>

    <div class="grid grid-cols-1 gap-8 lg:grid-cols-12">

      <div class="lg:col-span-8">
        <div class="rounded-md border border-slate-200 bg-white/80 p-6 shadow-sm backdrop-blur-sm">

          <!-- Drop zone -->
          <div
            class="relative mb-6 flex cursor-pointer flex-col items-center justify-center rounded-md border-2 border-dashed border-slate-200 bg-slate-50 px-6 py-10 text-center transition-colors hover:border-purple-300 hover:bg-purple-50/30"
            :class="dragOver ? 'border-purple-400 bg-purple-50/50' : ''"
            @dragover.prevent="dragOver = true"
            @dragleave="dragOver = false"
            @drop.prevent="handleDrop($event)"
            @click="$refs.fileInput.click()"
            role="button" tabindex="0"
            @keydown.enter="$refs.fileInput.click()"
            @keydown.space.prevent="$refs.fileInput.click()"
          >
            <span class="mb-2 text-3xl text-slate-300" aria-hidden="true">↓</span>
            <p class="text-sm font-medium text-slate-700">Drop an image here</p>
            <p class="mt-1 text-xs text-slate-400">PNG · JPG · WebP accepted</p>
            <input type="file" class="sr-only" accept="image/png,image/jpeg,image/webp"
              x-ref="fileInput" @change="handleFileInput($event)" />
          </div>

          <p x-show="fileInfo" class="mb-4 text-xs text-slate-500" x-text="fileInfo"></p>

          <div x-show="fileLoaded" class="flex flex-col gap-5">

            <!-- Dimensions -->
            <div class="grid gap-4 sm:grid-cols-3">
              <div>
                <label class="mb-1.5 block text-xs font-medium text-slate-600">Width (px)</label>
                <input type="number" min="1" max="8000"
                  class="w-full rounded-md border border-slate-200 bg-slate-50 px-3 py-2 text-sm text-slate-900 focus:border-purple-400 focus:outline-none focus:ring-2 focus:ring-purple-100"
                  x-model="w" @input="onWChange()" />
              </div>
              <div>
                <label class="mb-1.5 block text-xs font-medium text-slate-600">Height (px)</label>
                <input type="number" min="1" max="8000"
                  class="w-full rounded-md border border-slate-200 bg-slate-50 px-3 py-2 text-sm text-slate-900 focus:border-purple-400 focus:outline-none focus:ring-2 focus:ring-purple-100"
                  x-model="h" @input="onHChange()" />
              </div>
              <div class="flex items-end pb-2">
                <label class="flex cursor-pointer items-center gap-2 text-sm text-slate-600">
                  <input type="checkbox" class="accent-purple-500" x-model="lockAspect" />
                  Lock aspect ratio
                </label>
              </div>
            </div>

            <p x-show="origDims" class="text-xs text-slate-400" x-text="'Original: ' + origDims"></p>

            <!-- Crop thumbnail -->
            <div>
              <div class="mb-3 flex items-center justify-between">
                <p class="text-sm font-medium text-slate-700">Crop <span class="font-normal text-slate-400 text-xs">(drag to select)</span></p>
                <button x-show="cropW > 0" @click="clearCrop()"
                  class="rounded-md border border-rose-200 bg-rose-50 px-3 py-1 text-xs font-medium text-rose-600 transition-colors hover:bg-rose-100">
                  ✕ Reset crop
                </button>
              </div>

              <!-- Aspect presets -->
              <div class="mb-3 flex flex-wrap gap-1.5">
                <template x-for="p in presets" :key="p.label">
                  <button
                    class="rounded-md border px-3 py-1 text-sm font-medium transition-colors"
                    :class="aspectPreset === p.ratio ? 'border-purple-400 bg-purple-50 text-purple-700' : 'border-slate-200 text-slate-600 hover:border-slate-300'"
                    @click="applyPreset(p.ratio)"
                    x-text="p.label"
                  ></button>
                </template>
              </div>

              <!-- Thumbnail with crop canvas overlay -->
              <div class="relative inline-block max-w-full" x-ref="thumbWrap">
                <img :src="thumbSrc" x-ref="thumbImg"
                  class="block max-h-72 max-w-full rounded-md border border-slate-200 bg-slate-100"
                  draggable="false" />
                <canvas x-ref="cropCanvas"
                  class="absolute left-0 top-0 touch-none"
                  style="cursor:crosshair"
                  @pointerdown="startDraw($event)"
                  @pointermove="onMove($event)"
                  @pointerup="endDraw($event)"
                ></canvas>
              </div>

              <p x-show="cropW > 0" class="mt-1.5 text-xs text-slate-400"
                x-text="`Crop: ${cropW}×${cropH} px at (${cropX}, ${cropY})`"></p>
            </div>

            <!-- Fit mode -->
            <div>
              <p class="mb-2 text-xs font-medium text-slate-600">Fit mode</p>
              <div class="flex flex-wrap gap-2">
                <template x-for="mode in ['contain','cover','stretch','pad']" :key="mode">
                  <label
                    class="flex cursor-pointer items-center gap-2 rounded-md border px-3 py-2 text-sm transition-colors"
                    :class="fit === mode ? 'border-purple-400 bg-purple-50 text-purple-700' : 'border-slate-200 text-slate-600 hover:border-slate-300'"
                  >
                    <input type="radio" class="sr-only" :value="mode" x-model="fit" />
                    <span x-text="mode.charAt(0).toUpperCase() + mode.slice(1)"></span>
                  </label>
                </template>
              </div>
            </div>

            <!-- Pad colour -->
            <div x-show="fit === 'pad'" class="flex items-center gap-3">
              <label class="text-xs font-medium text-slate-600">Pad colour</label>
              <input type="color" class="h-8 w-14 cursor-pointer rounded border border-slate-200"
                x-model="padColor" @input="padColorHex = padColor" />
              <input type="text" maxlength="7" placeholder="#ffffff"
                class="w-28 rounded-md border border-slate-200 bg-slate-50 px-3 py-1.5 font-mono text-sm text-slate-900 focus:border-purple-400 focus:outline-none"
                x-model="padColorHex" @input="syncPadHex($event)" />
            </div>

            <!-- Output format -->
            <div class="max-w-xs">
              <label class="mb-1.5 block text-xs font-medium text-slate-600">Output format</label>
              <select class="w-full rounded-md border border-slate-200 bg-slate-50 px-3 py-2 text-sm text-slate-900 focus:border-purple-400 focus:outline-none" x-model="format">
                <option value="jpeg">JPEG</option>
                <option value="png">PNG</option>
                <option value="webp">WebP</option>
              </select>
            </div>

            <!-- Progress -->
            <div x-show="progress > 0" class="h-1.5 overflow-hidden rounded-full bg-slate-100">
              <div class="h-full rounded-full bg-purple-500 transition-all duration-300" :style="`width:${progress}%`"></div>
            </div>

            <!-- Action -->
            <button
              class="w-full rounded-md bg-gradient-to-br from-indigo-500 to-purple-500 px-6 py-3 text-sm font-semibold text-white transition-opacity disabled:opacity-50"
              :disabled="processing"
              @click="resize()"
            >
              <span x-show="!processing">Resize &amp; Download</span>
              <span x-show="processing">Processing…</span>
            </button>

            <!-- Status -->
            <p x-show="status" x-text="status" class="text-center text-sm"
              :class="{ 'text-emerald-600': statusType==='ok', 'text-rose-500': statusType==='err', 'text-slate-500': statusType==='info' }"></p>

            <!-- Preview -->
            <div x-show="previewSrc" class="mt-2">
              <p class="mb-2 text-xs font-medium uppercase tracking-wider text-slate-400">Output preview</p>
              <div class="overflow-hidden rounded-md border border-slate-200 bg-slate-50">
                <img :src="previewSrc" alt="Resized output preview" class="mx-auto max-h-96 w-auto object-contain" />
              </div>
            </div>

          </div>
        </div>
      </div>

      <aside class="lg:col-span-4">
        <div class="sticky top-8">
          <QuickTips tips={tips} cheatSheet={cheatSheet} />
        </div>
      </aside>

    </div>

    <!-- SEO Sandwich -->
    <div class="mt-16 rounded-md border border-slate-200 bg-slate-50 px-8 py-12">
      <div class="mx-auto max-w-2xl">
        <h2 class="mb-4 text-lg font-semibold text-slate-900">About Image Resizer</h2>
        <p class="mb-8 text-sm leading-relaxed text-slate-600">
          Resize any image to exact pixel dimensions in your browser. Choose from four fit modes — Contain (letterbox with transparency), Cover (crop and fill), Stretch (distort to exact size), or Pad (letterbox with a custom fill colour). Download the result as JPEG, PNG or WebP. All processing happens locally in your browser using the Canvas API.
        </p>
        <FAQAccordion items={faq} />
        <div class="mt-10 text-xs leading-relaxed text-slate-400">
          <p>Related: <a href="/tools/image-compress" class="text-purple-500 hover:underline">Image Compressor</a> · <a href="/tools/image-convert" class="text-purple-500 hover:underline">Image Converter</a> · <a href="/tools/ico-generator" class="text-purple-500 hover:underline">ICO Generator</a></p>
          <p class="mt-2">Keywords: resize image online, image resizer, crop image browser, contain cover stretch pad, no upload image resize</p>
        </div>
      </div>
    </div>

  </div>
</MainLayout>

<script>
  // Component logic + Alpine bootstrap live in a single shared module so that
  // Alpine knows about `imageResizer` before any x-data node is initialised,
  // even when this page is reached via an in-app View Transition.
  import '@/scripts/alpine';
</script>
