  "Make sure to utilize the authentication middleware in the context of this express application due to the fact that every endpoint is required to validate the authorization token prior to executing the request handler.",
  "I would really appreciate it if you could give me a regular expression for validating whether or not a password string is greater than or equal to 12 characters, contains a maximum of 3 repeated characters, and is not equal to any of the values in the previous passwords array.",
  "Just give me an example of how to remove an element from the DOM using standard JavaScript without using any external libraries.",
  "Can you please show me how to set up a proxy in the context of a webpack configuration due to the fact that the development environment is not equal to the production environment?",
  "I want you to be a systems architect. What is the best way to structure a message queue so that a large number of subscribers can consume from it without causing a bottleneck at the gateway?",
  "Take into consideration that the temporary buffer should be allocated prior to the asynchronous function executing and deallocated once the result is greater than or equal to the expected threshold.",
  "Could you walk me through how to implement a singleton pattern in typescript and make sure that the instance is strictly equals to null prior to initialization?"
];

// ─── DEFLUFFER INSTANCE (re-built when packs change) ─────────────────────────
function getActivePacks(): Record<string,string> {
  return Object.keys(domainPacks)
    .filter(id => (document.getElementById(id) as HTMLInputElement | null)?.checked)
    .reduce((acc, id) => ({ ...acc, ...domainPacks[id] }), {} as Record<string,string>);
}

let defluffer = new Defluffer(coreDictionaries, getActivePacks());

// ─── BENCHMARK (runs on base dict only — packs don't affect benchmark stats) ─
const benchDefluffer = new Defluffer(coreDictionaries);

const testResults = tests.map((original) => {
  const compressed = benchDefluffer.compress(original);
  const savings = parseFloat(((1 - compressed.length / original.length) * 100).toFixed(1));
  return { original, compressed, savings, origLen: original.length, compLen: compressed.length };
});

// ─── SUMMARY STATS ───────────────────────────────────────────────────────────
const avgSaving  = (testResults.reduce((a, r) => a + r.savings, 0) / testResults.length).toFixed(1);
const bestSaving = Math.max(...testResults.map(r => r.savings)).toFixed(1);
const totalOrig  = testResults.reduce((a, r) => a + r.origLen, 0);
const totalComp  = testResults.reduce((a, r) => a + r.compLen, 0);
const totalStripped = totalOrig - totalComp;
const tokensStripped = Math.round(totalStripped / 3.5);
const mwhStripped = (tokensStripped * 0.001 / 1000).toFixed(4);

(document.getElementById('sumAvgSaving') as HTMLElement).textContent  = avgSaving + '%';
(document.getElementById('sumBestSaving') as HTMLElement).textContent = bestSaving + '%';
(document.getElementById('sumTotalChars') as HTMLElement).textContent = totalStripped.toLocaleString();
(document.getElementById('sumLeaves') as HTMLElement).textContent     = mwhStripped;

// ─── RESULTS TABLE ───────────────────────────────────────────────────────────
function escHtml(s: string): string {
  return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

const resultsBody = document.getElementById('resultsBody') as HTMLElement;
testResults.forEach((r) => {
  const pct = r.savings;
  const cls = pct >= 40 ? 'high' : pct >= 20 ? 'mid' : 'low';
  const preview = r.original.length > 72 ? r.original.slice(0, 72) + '…' : r.original;

  const item = document.createElement('div');
  item.className = 'bench-item rounded-lg border border-slate-100 bg-slate-50 px-3 py-2 cursor-pointer hover:border-purple-200 hover:bg-purple-50/30 transition-colors';
  item.innerHTML = `
    <div class="flex items-center justify-between gap-3">
      <span class="bench-preview text-xs text-slate-500 truncate">${escHtml(preview)}</span>
      <div class="flex shrink-0 items-center gap-2">
        <span class="text-xs text-slate-400">${r.origLen}→${r.compLen}</span>
        <span class="savings-pct ${cls}">${pct}%</span>
        <span class="bench-chevron text-slate-300 text-xs">›</span>
      </div>
    </div>
    <div class="bench-detail hidden mt-3 space-y-2">
      <div>
        <p class="mb-1 text-xs font-medium text-slate-400">Original</p>
        <p class="text-xs text-slate-600 leading-relaxed">${escHtml(r.original)}</p>
      </div>
      <div class="border-t border-slate-100 pt-2">
        <p class="mb-1 text-xs font-medium text-purple-500">Compressed</p>
        <p class="text-xs text-slate-700 leading-relaxed font-mono">${escHtml(r.compressed)}</p>
      </div>
    </div>
  `;
  item.addEventListener('click', () => {
    const detail = item.querySelector('.bench-detail') as HTMLElement;
    const chevron = item.querySelector('.bench-chevron') as HTMLElement;
    const isOpen = !detail.classList.contains('hidden');
    detail.classList.toggle('hidden', isOpen);
    chevron.textContent = isOpen ? '›' : '⌄';
    item.classList.toggle('border-purple-200', !isOpen);
  });
  resultsBody.appendChild(item);
});

// ─── IMPACT CALCULATOR ───────────────────────────────────────────────────────
const CHARS_PER_TOKEN   = 3.5;
const MWH_PER_1K_TOKENS = 0.001;
const KG_CO2_PER_KWH    = 0.021;
const TREE_KG_PER_YEAR  = 21;
const PHONE_MWH         = 0.01;
const avgSavingFrac     = parseFloat(avgSaving) / 100;

function updateImpact() {
  const msgs = parseInt((document.getElementById('sliderMsgs') as HTMLInputElement).value);
  const len  = parseInt((document.getElementById('sliderLen')  as HTMLInputElement).value);
  const days = parseInt((document.getElementById('sliderDays') as HTMLInputElement).value);

  (document.getElementById('valMsgs') as HTMLElement).textContent = msgs.toString();
  (document.getElementById('valLen')  as HTMLElement).textContent = len.toString();
  (document.getElementById('valDays') as HTMLElement).textContent = days.toString();

  const charsPerYear = msgs * len * days;
  const charsSaved   = charsPerYear * avgSavingFrac;
  const tokensSaved  = Math.round(charsSaved / CHARS_PER_TOKEN);
  const mwhSaved     = tokensSaved * MWH_PER_1K_TOKENS / 1000;
  const kwhSaved     = mwhSaved * 1000;
  const kgCO2Saved   = kwhSaved * KG_CO2_PER_KWH;
  const treeDays     = ((kgCO2Saved / TREE_KG_PER_YEAR) * 365).toFixed(1);
  const phoneCharges = Math.round(mwhSaved / PHONE_MWH);

  (document.getElementById('impTokens') as HTMLElement).textContent = tokensSaved.toLocaleString();
  (document.getElementById('impEnergy') as HTMLElement).textContent = mwhSaved < 1
    ? mwhSaved.toFixed(4)
    : mwhSaved.toFixed(2);
  (document.getElementById('impTrees')  as HTMLElement).textContent = treeDays;
  (document.getElementById('impPhones') as HTMLElement).textContent = phoneCharges.toLocaleString();
}

['sliderMsgs','sliderLen','sliderDays'].forEach(id => {
  document.getElementById(id)!.addEventListener('input', updateImpact);
});
updateImpact();


// ─── DOMAIN PACK TOGGLES ─────────────────────────────────────────────────────
const PACK_STORAGE_KEY = 'ts-active-packs';

// Restore saved pack state
try {
  const saved = JSON.parse(localStorage.getItem(PACK_STORAGE_KEY) || '[]') as string[];
  saved.forEach(id => {
    const el = document.getElementById(id) as HTMLInputElement | null;
    if (el) el.checked = true;
  });
  defluffer = new Defluffer(coreDictionaries, getActivePacks());
} catch {}

document.getElementById('packToggles')!.addEventListener('change', () => {
  defluffer = new Defluffer(coreDictionaries, getActivePacks());
  const active = Object.keys(domainPacks).filter(id => (document.getElementById(id) as HTMLInputElement | null)?.checked);
  try { localStorage.setItem(PACK_STORAGE_KEY, JSON.stringify(active)); } catch {}
});

// ─── PLAYGROUND ──────────────────────────────────────────────────────────────
const inputEl   = document.getElementById('inputPrompt')   as HTMLTextAreaElement;
const outputEl  = document.getElementById('outputText')    as HTMLElement;
const inputCnt  = document.getElementById('inputCount')    as HTMLElement;
const outputCnt = document.getElementById('outputCount')   as HTMLElement;
const badge     = document.getElementById('savingsBadge')  as HTMLElement;
const savingsPctEl = document.getElementById('savingsPct') as HTMLElement;

inputEl.addEventListener('input', () => {
  inputCnt.textContent = inputEl.value.length + ' chars';
});

document.getElementById('btnCompress')!.addEventListener('click', () => {
  const raw = inputEl.value.trim();
  if (!raw) return;
  const result = defluffer.compress(raw);
  const pct = ((1 - result.length / raw.length) * 100).toFixed(1);
  outputEl.textContent = result;
  outputCnt.textContent = result.length + ' chars';
  savingsPctEl.textContent = pct + '%';
  badge.style.display = 'flex';

  // Show feedback trigger after each compression
  const feedbackArea = document.getElementById('feedbackArea') as HTMLElement;
  feedbackArea.classList.remove('hidden');
  // Reset the form state in case it was open from a prior run
  (document.getElementById('feedbackForm') as HTMLElement).classList.add('hidden');
  (document.getElementById('btnBadOutput') as HTMLElement).classList.remove('hidden');
  (document.getElementById('feedbackStatus') as HTMLElement).textContent = '';
  (document.getElementById('feedbackNote') as HTMLTextAreaElement).value = '';
});

document.getElementById('btnClear')!.addEventListener('click', () => {
  inputEl.value = '';
  outputEl.innerHTML = '<span class="text-slate-400">Your compressed prompt will appear here…</span>';
  inputCnt.textContent  = '0 chars';
  outputCnt.textContent = '0 chars';
  badge.style.display = 'none';
  (document.getElementById('feedbackArea') as HTMLElement).classList.add('hidden');
});

// ─── FEEDBACK ────────────────────────────────────────────────────────────────
document.getElementById('btnBadOutput')!.addEventListener('click', () => {
  (document.getElementById('feedbackForm') as HTMLElement).classList.remove('hidden');
  (document.getElementById('btnBadOutput') as HTMLElement).classList.add('hidden');
});

document.getElementById('btnCancelFeedback')!.addEventListener('click', () => {
  (document.getElementById('feedbackForm') as HTMLElement).classList.add('hidden');
  (document.getElementById('btnBadOutput') as HTMLElement).classList.remove('hidden');
  (document.getElementById('feedbackStatus') as HTMLElement).textContent = '';
});

document.getElementById('btnSubmitFeedback')!.addEventListener('click', async () => {
  const original   = inputEl.value.trim();
  const compressed = (outputEl.textContent ?? '').trim();
  const note       = (document.getElementById('feedbackNote') as HTMLTextAreaElement).value.trim();
  const statusEl   = document.getElementById('feedbackStatus') as HTMLElement;
  const btn        = document.getElementById('btnSubmitFeedback') as HTMLButtonElement;

  if (!original || !compressed || compressed === 'Your compressed prompt will appear here…') return;

  btn.disabled = true;
  statusEl.textContent = 'Sending…';

  try {
    const res = await fetch('/feedback', {
      method:  'POST',
      headers: { 'Content-Type': 'application/json' },
      body:    JSON.stringify({ original, compressed, note }),
    });
    if (res.ok) {
      (document.getElementById('feedbackForm') as HTMLElement).classList.add('hidden');
      statusEl.textContent = '✓ Thanks — your report helps improve the tool.';
      statusEl.classList.remove('text-rose-500');
      statusEl.classList.add('text-emerald-600');
      (document.getElementById('feedbackArea') as HTMLElement).appendChild(statusEl);
      statusEl.classList.remove('hidden');
    } else if (res.status === 409) {
      statusEl.textContent = 'Already reported.';
      statusEl.classList.add('text-rose-500');
      btn.disabled = false;
    } else if (res.status === 429) {
      statusEl.textContent = 'Too many reports today.';
      statusEl.classList.add('text-rose-500');
      btn.disabled = false;
    } else {
      statusEl.textContent = 'Something went wrong — try again.';
      statusEl.classList.add('text-rose-500');
      btn.disabled = false;
    }
  } catch (_) {
    statusEl.textContent = 'Network error — try again.';
    statusEl.classList.add('text-rose-500');
    btn.disabled = false;
  }
});

document.getElementById('btnCopy')!.addEventListener('click', function(this: HTMLElement) {
  const txt = outputEl.textContent ?? '';
  if (!txt || txt === 'Your compressed prompt will appear here…') return;
  navigator.clipboard.writeText(txt).then(() => {
    const orig = this.textContent!;
    this.textContent = '✓ copied';
    this.classList.add('text-emerald-600');
    setTimeout(() => { this.textContent = orig; this.classList.remove('text-emerald-600'); }, 1500);
  }).catch(() => {
    const orig = this.textContent!;
    this.textContent = 'failed';
    this.classList.add('text-rose-500');
    setTimeout(() => { this.textContent = orig; this.classList.remove('text-rose-500'); }, 1500);
  });
});
</script>
