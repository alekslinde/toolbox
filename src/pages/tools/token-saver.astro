---
import MainLayout from '@/layouts/MainLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import QuickTips from '@/components/QuickTips.astro';
import HelpfulButton from '@/components/HelpfulButton.astro';
import ToolSEO from '@/components/ToolSEO.astro';

const tips = [
  { heading: 'Phrase collapsing', body: 'Verbose filler like "could you please help me with" is removed or shortened to a tight equivalent.' },
  { heading: 'Synonym compression', body: 'Common long words — "application", "configuration", "authentication" — are swapped for their abbreviated forms.' },
  { heading: 'Code is protected', body: 'Content inside backtick code blocks is never touched; only the surrounding prose is compressed.' },
  { heading: 'Domain packs', body: 'Enable optional vocab packs in the compress section for deeper abbreviation in SQL, React, DevOps, UI, or UX contexts.' },
];

const faq = [
  { question: 'Will the compressed prompt give the same result?', answer: 'For most technical prompts, yes. The compressions use abbreviations and phrase-collapses that LLMs handle natively. Highly nuanced or creative prompts may benefit from lighter compression.' },
  { question: 'How are token savings estimated?', answer: 'Character savings are divided by 3.5, which is the rough average characters-per-token for abbreviated technical text with GPT-class tokenisers.' },
  { question: 'Is anything sent to a server?', answer: 'No. All compression runs entirely in your browser. Your prompt text never leaves your device.' },
  { question: 'What is the environmental impact calculation based on?', answer: 'A rough estimate of ~0.001 mWh per 1,000 tokens for GPT-4-class inference, 0.021 kg CO₂/kWh for the grid, and a tree absorbing ~21 kg CO₂/year.' },
];
---

<MainLayout
  title="AI Prompt Token Saver — Free In-Browser Tool | Toolbox"
  description="Compress verbose AI prompts to cut token usage. Collapses filler phrases, abbreviates common terms, and protects code blocks. Runs entirely in your browser."
  alpine={false}
>
  <div class="px-8 py-10 lg:px-8 max-w-[1440px] mx-auto">

    <div class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
      <div>
        <Breadcrumbs tool="Prompt Token Saver" category="Code & Web" />
        <h1 class="mt-3 text-2xl font-semibold tracking-tight text-slate-900">Prompt Token Saver</h1>
        <p class="mt-1 text-sm text-slate-500">Compress verbose AI prompts to reduce token usage — collapses filler phrases, abbreviates tech jargon, and never touches your code blocks.</p>
      </div>
      <HelpfulButton toolKey="token-saver" />
    </div>

    <div class="grid grid-cols-1 gap-8 lg:grid-cols-12">

      <!-- Left: Tool -->
      <div class="lg:col-span-8 space-y-6">

        <!-- Playground -->
        <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
          <h2 class="mb-4 text-sm font-semibold text-slate-700">Compress a Prompt</h2>

          <div class="mb-3">
            <div class="mb-1.5 flex items-center justify-between">
              <label for="inputPrompt" class="text-xs font-medium text-slate-600">Your prompt</label>
              <span id="inputCount" class="text-xs text-slate-400">0 chars</span>
            </div>
            <textarea id="inputPrompt" rows="6" spellcheck="false"
              placeholder="Paste your verbose prompt here…"
              class="w-full resize-y rounded-lg border border-slate-200 px-3 py-2 font-mono text-xs text-slate-800 focus:border-purple-400 focus:outline-none"></textarea>
          </div>

          <!-- Domain packs -->
          <div class="mb-4">
            <p class="mb-2 text-xs font-medium text-slate-600">Domain packs <span class="font-normal text-slate-400">(optional — enable extra abbreviations)</span></p>
            <div class="flex flex-wrap gap-2" id="packToggles">
              {[
                { id: 'pack-sql',    label: 'SQL / Database' },
                { id: 'pack-react',  label: 'React / Frontend' },
                { id: 'pack-devops', label: 'DevOps / K8s' },
                { id: 'pack-data',   label: 'Data Science / ML' },
                { id: 'pack-ui',     label: 'UI Design' },
                { id: 'pack-ux',     label: 'UX Research' },
              ].map(p => (
                <label class="flex cursor-pointer items-center gap-1.5 rounded-full border border-slate-200 px-3 py-1 text-xs text-slate-600 transition-colors hover:border-purple-300 has-[:checked]:border-purple-400 has-[:checked]:bg-purple-50 has-[:checked]:text-purple-700">
                  <input type="checkbox" id={p.id} class="h-3 w-3 accent-purple-500" />
                  {p.label}
                </label>
              ))}
            </div>
          </div>

          <div class="mb-4 flex flex-wrap gap-2">
            <button id="btnCompress"
              class="rounded-lg bg-gradient-to-br from-indigo-500 to-purple-500 px-5 py-2.5 text-sm font-medium text-white hover:opacity-90">
              Compress
            </button>
            <button id="btnClear"
              class="rounded-lg border border-slate-200 px-4 py-2 text-sm text-slate-600 hover:border-purple-300">
              Clear
            </button>
          </div>

          <div>
            <div class="mb-1.5 flex items-center justify-between">
              <label class="text-xs font-medium text-slate-600">Compressed output</label>
              <div class="flex items-center gap-3">
                <span id="outputCount" class="text-xs text-slate-400">0 chars</span>
                <span id="savingsBadge"
                  class="hidden items-center gap-1 rounded-full bg-emerald-50 px-2.5 py-0.5 text-xs font-semibold text-emerald-700">
                  <span>↓</span><span id="savingsPct"></span> saved
                </span>
                <button id="btnCopy" class="text-xs text-slate-400 hover:text-purple-600">copy</button>
              </div>
            </div>
            <div id="outputText"
              class="min-h-[6rem] w-full rounded-lg border border-slate-200 bg-slate-50 px-3 py-2 font-mono text-xs text-slate-700 whitespace-pre-wrap break-words">
              <span class="output-placeholder text-slate-400">Your compressed prompt will appear here…</span>
            </div>
          </div>

          <!-- Feedback -->
          <div id="feedbackArea" class="hidden mt-3">
            <button id="btnBadOutput"
              class="flex items-center gap-1.5 text-xs text-slate-400 hover:text-rose-500 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor">
                <path d="M18 9.5a1.5 1.5 0 11-3 0v-6a1.5 1.5 0 013 0v6zM14 9.667v-5.43a2 2 0 00-1.105-1.79l-.05-.025A4 4 0 0011.055 2H5.64a2 2 0 00-1.962 1.608l-1.2 6A2 2 0 004.44 12H8v4a2 2 0 002 2 1 1 0 001-1v-.667l1.5-2.333H14z" />
              </svg>
              Bad output? Report it
            </button>
            <div id="feedbackForm" class="hidden mt-2 rounded-lg border border-rose-100 bg-rose-50/60 p-3 space-y-2">
              <p class="text-xs text-slate-500">What went wrong? <span class="text-slate-400">(optional — 280 chars max)</span></p>
              <textarea id="feedbackNote" rows="2" maxlength="280"
                placeholder="e.g. 'auth' is wrong here — it changed the meaning"
                class="w-full resize-none rounded-md border border-rose-200 bg-white px-2.5 py-1.5 text-xs text-slate-700 focus:border-rose-400 focus:outline-none"></textarea>
              <div class="flex items-center gap-2">
                <button id="btnSubmitFeedback"
                  class="rounded-md bg-rose-500 px-3 py-1.5 text-xs font-medium text-white hover:bg-rose-600">
                  Submit report
                </button>
                <button id="btnCancelFeedback"
                  class="text-xs text-slate-400 hover:text-slate-600">
                  Cancel
                </button>
                <span id="feedbackStatus" class="ml-auto text-xs text-slate-400"></span>
              </div>
            </div>
          </div>
        </div>

        <!-- Impact calculator -->
        <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
          <h2 class="mb-1 text-sm font-semibold text-slate-700">Environmental Impact Calculator</h2>
          <p class="mb-5 text-xs text-slate-400">Estimate how much energy you save by compressing your prompts over time.</p>

          <div class="space-y-4 mb-6">
            <div>
              <div class="mb-1 flex justify-between text-xs text-slate-500">
                <span>Prompts per day</span><span id="valMsgs" class="font-medium text-slate-700">20</span>
              </div>
              <input type="range" id="sliderMsgs" min="1" max="200" value="20"
                class="w-full accent-purple-500" />
            </div>
            <div>
              <div class="mb-1 flex justify-between text-xs text-slate-500">
                <span>Avg. prompt length (chars)</span><span id="valLen" class="font-medium text-slate-700">500</span>
              </div>
              <input type="range" id="sliderLen" min="50" max="5000" step="50" value="500"
                class="w-full accent-purple-500" />
            </div>
            <div>
              <div class="mb-1 flex justify-between text-xs text-slate-500">
                <span>Days per year active</span><span id="valDays" class="font-medium text-slate-700">250</span>
              </div>
              <input type="range" id="sliderDays" min="1" max="365" value="250"
                class="w-full accent-purple-500" />
            </div>
          </div>

          <div class="grid grid-cols-2 gap-3 sm:grid-cols-4">
            <div class="rounded-lg bg-slate-50 p-3 text-center">
              <div id="impTokens" class="text-lg font-bold text-purple-600">—</div>
              <div class="mt-0.5 text-xs text-slate-500">tokens saved/yr</div>
            </div>
            <div class="rounded-lg bg-slate-50 p-3 text-center">
              <div id="impEnergy" class="text-lg font-bold text-indigo-600">—</div>
              <div class="mt-0.5 text-xs text-slate-500">mWh saved/yr</div>
            </div>
            <div class="rounded-lg bg-slate-50 p-3 text-center">
              <div id="impTrees" class="text-lg font-bold text-emerald-600">—</div>
              <div class="mt-0.5 text-xs text-slate-500">tree-days equivalent</div>
            </div>
            <div class="rounded-lg bg-slate-50 p-3 text-center">
              <div id="impPhones" class="text-lg font-bold text-amber-600">—</div>
              <div class="mt-0.5 text-xs text-slate-500">phone charges equiv.</div>
            </div>
          </div>
        </div>

        <!-- Test suite summary -->
        <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
          <h2 class="mb-1 text-sm font-semibold text-slate-700">Benchmark — 29 Real-World Prompts</h2>
          <p class="mb-5 text-xs text-slate-400">Average compression across a suite of verbose developer prompts.</p>

          <div class="mb-6 grid grid-cols-2 gap-3 sm:grid-cols-4">
            <div class="rounded-lg bg-slate-50 p-3 text-center">
              <div id="sumAvgSaving" class="text-lg font-bold text-purple-600">—</div>
              <div class="mt-0.5 text-xs text-slate-500">avg chars saved</div>
            </div>
            <div class="rounded-lg bg-slate-50 p-3 text-center">
              <div id="sumBestSaving" class="text-lg font-bold text-indigo-600">—</div>
              <div class="mt-0.5 text-xs text-slate-500">best case</div>
            </div>
            <div class="rounded-lg bg-slate-50 p-3 text-center">
              <div id="sumTotalChars" class="text-lg font-bold text-emerald-600">—</div>
              <div class="mt-0.5 text-xs text-slate-500">total chars stripped</div>
            </div>
            <div class="rounded-lg bg-slate-50 p-3 text-center">
              <div id="sumLeaves" class="text-lg font-bold text-amber-600">—</div>
              <div class="mt-0.5 text-xs text-slate-500">mWh saved (bench)</div>
            </div>
          </div>

          <div id="resultsBody" class="max-h-96 overflow-y-auto space-y-1 pr-1"></div>
        </div>

      </div>

      <!-- Right: Quick tips -->
      <aside class="lg:col-span-4">
        <div class="sticky top-8">
          <QuickTips tips={tips} />
        </div>
      </aside>

    </div>

    <ToolSEO
      heading="About Prompt Token Saver"
      faq={faq}
      related={`<a href="/tools/code-formatter" class="text-purple-500 hover:underline">Code Formatter</a> · <a href="/tools/semantic-html" class="text-purple-500 hover:underline">Semantic HTML Converter</a>`}
      keywords="prompt compression, token saver, LLM token reduction, AI prompt optimizer, reduce AI costs, GPT token counter"
    >
      <p slot="description" class="mb-8 text-sm leading-relaxed text-slate-600">
        Verbose AI prompts waste tokens — and tokens cost money, latency, and energy. This tool compresses your prompt by collapsing filler phrases ("could you please help me with" → ""), abbreviating common technical terms ("authentication" → "auth", "configuration" → "config"), and applying logic symbol substitutions ("greater than or equal to" → ">="). Code blocks are automatically protected and passed through unchanged. Savings of 20–50% are typical for developer-style prompts.
      </p>
    </ToolSEO>

  </div>
</MainLayout>

<style>
  .savings-pct { display: inline-block; border-radius: 9999px; padding: 1px 8px; font-size: 0.7rem; font-weight: 600; }
  .savings-pct.high { background: #d1fae5; color: #065f46; }
  .savings-pct.mid  { background: #fef3c7; color: #92400e; }
  .savings-pct.low  { background: #f1f5f9; color: #64748b; }
</style>

