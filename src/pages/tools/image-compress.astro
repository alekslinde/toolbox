---
import MainLayout from '@/layouts/MainLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import QuickTips from '@/components/QuickTips.astro';
import FAQAccordion from '@/components/FAQAccordion.astro';

const tips = [
  { heading: 'JPEG for photos',   body: 'Lossy compression — 75–85% quality is usually indistinguishable from lossless.' },
  { heading: 'PNG for graphics',  body: 'Lossless — preserves hard edges, text and transparency. Larger than JPEG for photos.' },
  { heading: 'WebP for web',      body: 'Modern format with ~30% better compression than JPEG at equivalent quality.' },
  { heading: 'SVG minification',  body: 'Strips comments, metadata and whitespace. Vector quality is never degraded.' },
  { heading: 'Max dimension',     body: 'Optional — downscales before encoding. Useful for removing unnecessary resolution.' },
];

const cheatSheet = [
  { label: 'JPEG',  value: 'Photos, no transparency' },
  { label: 'PNG',   value: 'Graphics, logos, transparency' },
  { label: 'WebP',  value: 'Best web compression' },
  { label: 'SVG',   value: 'Icons, illustrations (vector)' },
];

const faq = [
  {
    question: 'Is my image uploaded to a server?',
    answer: 'No. Everything runs inside your browser using the Canvas API. Your file never leaves your device.',
  },
  {
    question: 'What formats are supported?',
    answer: 'Input: PNG, JPEG, WebP and SVG. Output: JPEG, PNG, WebP (choose in the Format dropdown), or SVG minification when an SVG is loaded.',
  },
  {
    question: 'Why is the output larger than the original?',
    answer: 'Re-encoding a heavily compressed JPEG at a higher quality setting, or converting to a less efficient format, can increase size. Lower the quality or switch to WebP for smaller output.',
  },
  {
    question: 'Does the quality slider affect PNG output?',
    answer: 'No — PNG is lossless so the quality slider is hidden when PNG is selected. The only way to reduce PNG file size is to lower the resolution or convert to WebP.',
  },
  {
    question: 'What does "Max dimension" do?',
    answer: 'It constrains the longest edge of the image to the value you enter (in pixels), scaling proportionally before encoding. Leave it blank to keep the original dimensions.',
  },
];
---

<MainLayout
  title="Image Compressor — Free In-Browser Tool | Toolbox"
  description="Compress PNG, JPG, WebP and SVG images in-browser with live before/after size comparison. No uploads, no account, no limits."
  alpine={true}
>
  <div class="px-8 py-10 lg:px-8 max-w-[1440px] mx-auto" x-data="imageCompressor">

    <!-- Top bar -->
    <div class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
      <div>
        <Breadcrumbs tool="Image Compressor" category="Images & Documents" />
        <h1 class="mt-3 text-2xl font-semibold tracking-tight text-slate-900">Image Compressor</h1>
        <p class="mt-1 text-sm text-slate-500">
          Compress PNG, JPG, WebP and SVG files in-browser. Live before/after size comparison.
        </p>
      </div>

      <!-- "This helped me" -->
      <button
        class="flex shrink-0 items-center gap-2 self-start rounded-full border border-slate-200 bg-white px-4 py-2 text-sm text-slate-500 shadow-sm transition-all hover:border-purple-200 hover:text-purple-600"
        @click="helpful++"
        :class="helpful > 0 ? 'border-purple-300 bg-purple-50 text-purple-600' : ''"
      >
        <span>👍</span>
        <span>This helped me</span>
        <span x-show="helpful > 0" class="font-semibold text-purple-600" x-text="helpful"></span>
      </button>
    </div>

    <!-- Two-column layout -->
    <div class="grid grid-cols-1 gap-8 lg:grid-cols-12">

      <!-- Left: Tool workstation (8 cols) -->
      <div class="lg:col-span-8">
        <div class="rounded-md border border-slate-200 bg-white/80 p-6 shadow-sm backdrop-blur-sm">

          <!-- Drop zone -->
          <div
            class="relative mb-6 flex flex-col items-center justify-center rounded-md border-2 border-dashed border-slate-200 bg-slate-50 px-6 py-10 text-center transition-colors hover:border-purple-300 hover:bg-purple-50/30"
            :class="dragOver ? 'border-purple-400 bg-purple-50/50' : ''"
            @dragover.prevent="dragOver = true"
            @dragleave="dragOver = false"
            @drop.prevent="handleDrop($event)"
            @click="$refs.fileInput.click()"
            role="button"
            tabindex="0"
            @keydown.enter="$refs.fileInput.click()"
            @keydown.space.prevent="$refs.fileInput.click()"
            aria-label="Drop image or click to browse"
          >
            <span class="mb-2 text-3xl text-slate-300" aria-hidden="true">↓</span>
            <p class="text-sm font-medium text-slate-700">Drop an image here</p>
            <p class="mt-1 text-xs text-slate-400">PNG · JPG · WebP · SVG accepted</p>
            <input
              type="file"
              class="sr-only"
              accept="image/png,image/jpeg,image/webp,image/svg+xml"
              x-ref="fileInput"
              @change="handleFileInput($event)"
            />
          </div>

          <!-- File info -->
          <p x-show="fileInfo" class="mb-4 text-xs text-slate-500" x-text="fileInfo"></p>

          <!-- Controls (shown after file load) -->
          <div x-show="fileLoaded" class="flex flex-col gap-5">

            <!-- Format + quality row -->
            <div class="grid gap-4 sm:grid-cols-2">
              <div>
                <label class="mb-1.5 block text-xs font-medium text-slate-600" for="out-fmt">Output format</label>
                <select
                  id="out-fmt"
                  class="w-full rounded-md border border-slate-200 bg-slate-50 px-3 py-2 text-sm text-slate-900 focus:border-purple-400 focus:outline-none focus:ring-2 focus:ring-purple-100"
                  x-model="format"
                  @change="onFormatChange()"
                >
                  <option value="jpeg">JPEG</option>
                  <option value="png">PNG (lossless)</option>
                  <option value="webp">WebP</option>
                  <option value="svg">SVG (minify)</option>
                </select>
              </div>

              <div x-show="format !== 'png' && format !== 'svg'">
                <label class="mb-1.5 block text-xs font-medium text-slate-600" :for="'quality'">
                  Quality — <span class="text-purple-600 font-semibold" x-text="quality + '%'"></span>
                </label>
                <input
                  id="quality"
                  type="range"
                  min="10" max="100" step="1"
                  class="w-full accent-purple-500"
                  x-model="quality"
                />
              </div>
            </div>

            <!-- Max dimension -->
            <div x-show="format !== 'svg'">
              <label class="mb-1.5 block text-xs font-medium text-slate-600" for="max-dim">Max dimension (px) — optional</label>
              <input
                id="max-dim"
                type="number"
                min="16" max="8000"
                placeholder="e.g. 1920 — leave blank to keep original"
                class="w-full rounded-md border border-slate-200 bg-slate-50 px-3 py-2 text-sm text-slate-900 placeholder:text-slate-400 focus:border-purple-400 focus:outline-none focus:ring-2 focus:ring-purple-100"
                x-model="maxDim"
              />
            </div>

            <!-- Stats grid -->
            <div class="grid grid-cols-2 gap-3 sm:grid-cols-4" x-show="origSize">
              <div class="rounded-md bg-slate-50 p-3">
                <p class="text-[10px] font-medium uppercase tracking-wider text-slate-400">Original</p>
                <p class="mt-1 text-sm font-semibold text-slate-800" x-text="origSize"></p>
              </div>
              <div class="rounded-md bg-slate-50 p-3">
                <p class="text-[10px] font-medium uppercase tracking-wider text-slate-400">Output</p>
                <p class="mt-1 text-sm font-semibold text-slate-800" x-text="outSize || '—'"></p>
              </div>
              <div class="rounded-md bg-slate-50 p-3">
                <p class="text-[10px] font-medium uppercase tracking-wider text-slate-400">Orig dims</p>
                <p class="mt-1 text-sm font-semibold text-slate-800" x-text="origDims || '—'"></p>
              </div>
              <div class="rounded-md bg-slate-50 p-3">
                <p class="text-[10px] font-medium uppercase tracking-wider text-slate-400">Out dims</p>
                <p class="mt-1 text-sm font-semibold text-slate-800" x-text="outDims || '—'"></p>
              </div>
            </div>

            <!-- Progress bar -->
            <div x-show="progress > 0" class="h-1.5 overflow-hidden rounded-full bg-slate-100">
              <div
                class="h-full rounded-full bg-purple-500 transition-all duration-300"
                :style="`width: ${progress}%`"
              ></div>
            </div>

            <!-- Action button -->
            <button
              class="w-full rounded-md bg-gradient-to-br from-indigo-500 to-purple-500 px-6 py-3 text-sm font-semibold text-white transition-opacity disabled:opacity-50"
              :disabled="processing"
              @click="compress()"
            >
              <span x-show="!processing">Preview & Download</span>
              <span x-show="processing">Processing…</span>
            </button>

            <!-- Status -->
            <p
              x-show="status"
              x-text="status"
              class="text-center text-sm"
              :class="{
                'text-emerald-600': statusType === 'ok',
                'text-rose-500':    statusType === 'err',
                'text-slate-500':   statusType === 'info',
              }"
            ></p>

            <!-- Preview -->
            <div x-show="previewSrc" class="mt-2">
              <p class="mb-2 text-xs font-medium uppercase tracking-wider text-slate-400">Output preview</p>
              <div class="overflow-hidden rounded-md border border-slate-200 bg-slate-50">
                <img
                  :src="previewSrc"
                  alt="Compressed output preview"
                  class="mx-auto max-h-96 w-auto object-contain"
                />
              </div>
            </div>

            <!-- Saving badge -->
            <p
              x-show="savingBadge"
              x-text="savingBadge"
              class="text-center text-sm font-semibold"
              :class="savingPositive ? 'text-emerald-600' : 'text-rose-500'"
            ></p>
          </div>

        </div>
      </div>

      <!-- Right: Quick reference (4 cols) -->
      <aside class="lg:col-span-4">
        <div class="sticky top-8">
          <QuickTips tips={tips} cheatSheet={cheatSheet} />
        </div>
      </aside>

    </div>

    <!-- SEO Sandwich -->
    <div class="mt-16 rounded-md border border-slate-200 bg-slate-50 px-8 py-12">
      <div class="mx-auto max-w-2xl">

        <h2 class="mb-6 text-lg font-semibold text-slate-900">How to compress an image in-browser</h2>
        <ol class="mb-10 flex flex-col gap-3 text-sm leading-relaxed text-slate-600">
          <li class="flex gap-3">
            <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-purple-100 text-xs font-semibold text-purple-600">1</span>
            <span><strong class="text-slate-800">Drop or select your image.</strong> PNG, JPEG, WebP and SVG files are all accepted.</span>
          </li>
          <li class="flex gap-3">
            <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-purple-100 text-xs font-semibold text-purple-600">2</span>
            <span><strong class="text-slate-800">Choose an output format.</strong> JPEG for photos, PNG for graphics, WebP for the best web compression.</span>
          </li>
          <li class="flex gap-3">
            <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-purple-100 text-xs font-semibold text-purple-600">3</span>
            <span><strong class="text-slate-800">Adjust quality and max dimension.</strong> Quality 75–85 is virtually lossless for JPEG. Max dimension lets you downscale without a separate resize step.</span>
          </li>
          <li class="flex gap-3">
            <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-purple-100 text-xs font-semibold text-purple-600">4</span>
            <span><strong class="text-slate-800">Click "Preview & Download".</strong> The file downloads instantly and the output preview appears below the controls.</span>
          </li>
        </ol>

        <h2 class="mb-6 text-lg font-semibold text-slate-900">Frequently asked questions</h2>
        <FAQAccordion items={faq} />

        <div class="mt-10 text-xs leading-relaxed text-slate-400">
          <p>
            Related tools: <a href="/tools/image-resize" class="text-purple-500 hover:underline">Image Resizer</a> ·
            <a href="/tools/image-convert" class="text-purple-500 hover:underline">Image Converter</a> ·
            <a href="/tools/ico-generator" class="text-purple-500 hover:underline">ICO Favicon Generator</a> ·
            <a href="/tools/pdf-compress" class="text-purple-500 hover:underline">PDF Compressor</a>
          </p>
          <p class="mt-2">Keywords: image compressor, compress PNG online, reduce JPEG file size, WebP converter, SVG minifier, browser-based image tool, no upload image compress</p>
        </div>

      </div>
    </div>

  </div>
</MainLayout>

<script>
  // Component logic + Alpine bootstrap live in a single shared module so that
  // Alpine knows about `imageCompressor` before any x-data node is initialised,
  // even when this page is reached via an in-app View Transition.
  import '@/scripts/alpine';
</script>
