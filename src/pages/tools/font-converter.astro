---
import MainLayout from '@/layouts/MainLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import QuickTips from '@/components/QuickTips.astro';
import HelpfulButton from '@/components/HelpfulButton.astro';
import ToolSEO from '@/components/ToolSEO.astro';

const tips = [
  { heading: 'Extension renaming ≠ conversion', body: 'Renaming font.otf to font.ttf changes nothing — browsers read the binary file signature, not the filename. Only a real conversion changes the internal structure.' },
  { heading: 'Prefer TTF or OTF as source', body: 'WOFF and WOFF2 are compressed wrappers around the original outline data. Converting from an uncompressed source preserves the most fidelity and avoids round-trip artefacts.' },
  { heading: 'WOFF2 input works directly', body: 'Drop a .woff2 file straight in — it is decompressed automatically in your browser before conversion. No manual steps or external tools needed.' },
  { heading: 'If conversion fails, try TTF first', body: 'Convert to TTF as an intermediate step, then convert that file to your target format. This works around most parsing edge cases.' },
];

const faq = [
  { question: 'Is my font uploaded?', answer: 'No. Conversion happens entirely in your browser using opentype.js and wawoff2 (WebAssembly). Your font file never leaves your device.' },
  { question: 'What input formats are supported?', answer: 'TTF, OTF, WOFF and WOFF2. WOFF2 files are decompressed in the browser using a WebAssembly port of the reference WOFF2 library before conversion.' },
  { question: 'Can I export WOFF2?', answer: 'Yes. WOFF2 output is supported via the same WebAssembly library used for input — no server required.' },
];
---

<MainLayout
  title="Font Converter — Free In-Browser Tool | Toolbox"
  description="Convert fonts between TTF, OTF, WOFF and EOT in your browser. No uploads. Powered by opentype.js."
  alpine={false}
>
  <div class="px-8 py-10 lg:px-14">

    <div class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
      <div>
        <Breadcrumbs tool="Font Converter" category="Typography & Color" />
        <h1 class="mt-3 text-2xl font-semibold tracking-tight text-slate-900">Font Converter</h1>
        <p class="mt-1 text-sm text-slate-500">Convert between TTF, OTF, WOFF, WOFF2 and EOT — in your browser.</p>
      </div>
      <HelpfulButton />
    </div>

    <div class="grid grid-cols-1 gap-8 lg:grid-cols-12">

      <div class="lg:col-span-8">
        <div class="rounded-md border border-slate-200 bg-white/80 p-6 shadow-sm backdrop-blur-sm">

          <!-- Drop zone -->
          <div id="fontDropZone"
            class="relative mb-6 flex cursor-pointer flex-col items-center justify-center rounded-md border-2 border-dashed border-slate-200 bg-slate-50 px-6 py-10 text-center transition-colors hover:border-purple-300 hover:bg-purple-50/30"
            role="button" tabindex="0"
          >
            <span class="mb-2 text-3xl text-slate-300" aria-hidden="true">↓</span>
            <p class="text-sm font-medium text-slate-700">Drop a font file here</p>
            <p class="mt-1 text-xs text-slate-400">TTF · OTF · WOFF · WOFF2 accepted</p>
            <input id="fontFileInput" type="file" class="sr-only" accept=".ttf,.otf,.woff,.woff2,font/ttf,font/otf,font/woff,font/woff2" />
          </div>

          <p id="fontFileInfo" class="mb-2 hidden text-xs text-slate-500"></p>
          <div id="fontDiag" class="hidden mb-4 rounded-md border px-3 py-2.5 text-xs leading-relaxed"></div>

          <div id="fontControls" class="hidden flex-col gap-4">

            <div class="grid gap-4 sm:grid-cols-2">
              <div>
                <label class="mb-1.5 block text-xs font-medium text-slate-600">Convert to</label>
                <select id="fontTo"
                  class="w-full rounded-md border border-slate-200 bg-slate-50 px-3 py-2 text-sm text-slate-900 focus:border-purple-400 focus:outline-none">
                  <option value="woff2">WOFF2</option>
                  <option value="woff">WOFF</option>
                  <option value="ttf">TTF</option>
                  <option value="otf">OTF</option>
                  <option value="eot">EOT</option>
                </select>
              </div>
            </div>

            <!-- Progress -->
            <div id="fontPBar" class="hidden h-1.5 overflow-hidden rounded-full bg-slate-100">
              <div id="fontPFill" class="h-full rounded-full bg-purple-500 transition-all duration-300" style="width:0%"></div>
            </div>

            <button id="fontConvertBtn"
              class="w-full rounded-md bg-gradient-to-br from-indigo-500 to-purple-500 px-6 py-3 text-sm font-semibold text-white transition-opacity disabled:opacity-50"
              disabled
            >
              Convert &amp; Download
            </button>

            <p id="fontStatus" class="hidden text-center text-sm"></p>

          </div>

        </div>
      </div>

      <aside class="lg:col-span-4">
        <div class="sticky top-8 flex flex-col gap-4">
          <QuickTips tips={tips} />

          <!-- Font format reference -->
          <div class="rounded-md border border-slate-200 bg-white p-5 shadow-sm">
            <h3 class="mb-3 text-xs font-semibold uppercase tracking-widest text-slate-400">Font Formats</h3>
            <ul class="flex flex-col divide-y divide-slate-100">

              <li class="py-3 first:pt-0 last:pb-0">
                <div class="mb-1 flex items-center gap-2">
                  <span class="rounded bg-purple-100 px-1.5 py-0.5 font-mono text-xs font-semibold text-purple-700">WOFF2</span>
                  <span class="text-xs font-medium text-emerald-600">best for web</span>
                </div>
                <p class="text-xs text-slate-500">Brotli-compressed sfnt. ~30% smaller than WOFF. Supported in every modern browser.</p>
              </li>

              <li class="py-3 first:pt-0 last:pb-0">
                <div class="mb-1 flex items-center gap-2">
                  <span class="rounded bg-slate-100 px-1.5 py-0.5 font-mono text-xs font-semibold text-slate-600">WOFF</span>
                  <span class="text-xs font-medium text-slate-400">web fallback</span>
                </div>
                <p class="text-xs text-slate-500">zlib-compressed sfnt. Use as a fallback alongside WOFF2 if you need IE9+ support.</p>
              </li>

              <li class="py-3 first:pt-0 last:pb-0">
                <div class="mb-1 flex items-center gap-2">
                  <span class="rounded bg-slate-100 px-1.5 py-0.5 font-mono text-xs font-semibold text-slate-600">TTF</span>
                  <span class="rounded bg-slate-100 px-1.5 py-0.5 font-mono text-xs font-semibold text-slate-600">OTF</span>
                  <span class="text-xs font-medium text-slate-400">desktop / source</span>
                </div>
                <p class="text-xs text-slate-500">Uncompressed outlines — TTF uses TrueType curves, OTF uses PostScript (CFF). Ideal starting point for conversion.</p>
              </li>

              <li class="py-3 first:pt-0 last:pb-0">
                <div class="mb-1 flex items-center gap-2">
                  <span class="rounded bg-slate-100 px-1.5 py-0.5 font-mono text-xs font-semibold text-slate-600">EOT</span>
                  <span class="text-xs font-medium text-slate-400">legacy IE only</span>
                </div>
                <p class="text-xs text-slate-500">Embedded OpenType for Internet Explorer 6–8. Skip unless you specifically need old-IE support.</p>
              </li>

            </ul>
          </div>
        </div>
      </aside>

    </div>

    <ToolSEO
      heading="About Font Converter"
      faq={faq}
      related={`<a href="/tools/font-inspector" class="text-purple-500 hover:underline">Font Inspector</a> · <a href="/tools/ico-generator" class="text-purple-500 hover:underline">ICO Generator</a>`}
      keywords="font converter, TTF to WOFF, OTF to WOFF2, web font converter, browser font conversion, no upload font tool"
    >
      <p slot="description" class="mb-8 text-sm leading-relaxed text-slate-600">Convert font files between TTF, OTF, WOFF, WOFF2 and EOT formats entirely in your browser. WOFF2 input is decompressed using a WebAssembly build of the reference WOFF2 library before opentype.js parses the font. WOFF2 output is compressed the same way — no server needed.</p>
    </ToolSEO>

  </div>
</MainLayout>

<script>
  import * as opentype from 'opentype.js';
  // @ts-ignore
  import wawoff2Decompress from 'wawoff2/decompress';
  // @ts-ignore
  import wawoff2Compress from 'wawoff2/compress';

  async function decompressWOFF2(buf: Uint8Array): Promise<Uint8Array> {
    return wawoff2Decompress(buf);
  }

  async function compressWOFF2(buf: Uint8Array): Promise<Uint8Array> {
    return wawoff2Compress(buf);
  }

  /* ── Structural validation ── */
  interface DiagResult { issues: string[]; warnings: string[] }

  function inspectSfnt(buf: ArrayBuffer): DiagResult {
    const dv = new DataView(buf);
    const size = buf.byteLength;
    const issues: string[] = [];
    const warnings: string[] = [];

    if (size < 12) {
      issues.push('File is too small to contain a font header — it may be truncated or empty.');
      return { issues, warnings };
    }

    const magic = dv.getUint32(0);
    const sfntMagics = new Set([0x00010000, 0x4F54544F, 0x74727565, 0x74797031]);
    if (!sfntMagics.has(magic)) {
      const hex = '0x' + magic.toString(16).toUpperCase().padStart(8, '0');
      issues.push(`Unexpected file signature (${hex}). The file may have been renamed rather than converted.`);
      return { issues, warnings };
    }

    const isOTF = magic === 0x4F54544F;
    const numTables = dv.getUint16(4);
    const dirEnd = 12 + numTables * 16;

    if (size < dirEnd) {
      issues.push(`Table directory claims ${numTables} tables but the file is only ${size} bytes — it is likely truncated.`);
      return { issues, warnings };
    }

    const found = new Set<string>();
    for (let i = 0; i < numTables; i++) {
      const o = 12 + i * 16;
      const tag = String.fromCharCode(dv.getUint8(o), dv.getUint8(o+1), dv.getUint8(o+2), dv.getUint8(o+3)).trimEnd();
      const offset = dv.getUint32(o + 8);
      const length = dv.getUint32(o + 12);
      found.add(tag);
      if (offset + length > size) {
        issues.push(`Table '${tag}' extends beyond the end of the file (starts at byte ${offset}, length ${length}, file is ${size} bytes).`);
      }
    }

    const required = ['cmap', 'head', 'hhea', 'hmtx', 'maxp', 'name', 'post'];
    for (const t of required) {
      if (!found.has(t)) issues.push(`Required table '${t}' is missing.`);
    }

    if (!found.has('glyf') && !found.has('CFF ') && !found.has('CFF2')) {
      issues.push(`No glyph outline table found — expected 'glyf' (TrueType) or 'CFF '/'CFF2' (PostScript/OTF).`);
    }
    if (isOTF && found.has('glyf') && !found.has('CFF ')) {
      warnings.push(`File header says OTF (OTTO) but contains a 'glyf' table instead of 'CFF '. The flavour may be mislabelled.`);
    }

    return { issues, warnings };
  }

  /* ── Name-record repair ── */
  function repairNameRecords(font: any, fallback: string): string[] {
    const repairs: string[] = [];

    // getEnglishName() reads from (unicode || macintosh || windows)[key].
    // Patching font.names directly is ignored — we must write to the same platform
    // object that getEnglishName() and toArrayBuffer() will read from.
    const platform: Record<string, any> =
      font.names.unicode ?? font.names.macintosh ?? font.names.windows ?? font.names;

    function patch(key: string, value: string) { platform[key] = { en: value }; }

    if (!font.getEnglishName('fontFamily')) {
      // preferredFamily is more accurate than the filename when present
      const family = font.getEnglishName('preferredFamily') ?? fallback;
      patch('fontFamily', family);
      repairs.push(`added missing 'fontFamily' → "${family}"`);
    }
    if (!font.getEnglishName('fontSubfamily')) {
      const sub = font.getEnglishName('preferredSubfamily') ?? 'Regular';
      patch('fontSubfamily', sub);
      repairs.push(`added missing 'fontSubfamily' → "${sub}"`);
    }
    if (!font.getEnglishName('postScriptName')) {
      const family = font.getEnglishName('fontFamily') ?? fallback;
      const psName = family.replace(/\s+/g, '');
      patch('postScriptName', psName);
      repairs.push(`added missing 'postScriptName' → "${psName}"`);
    }
    if (!font.getEnglishName('fullName')) {
      const family = font.getEnglishName('fontFamily') ?? fallback;
      const sub = font.getEnglishName('fontSubfamily') ?? 'Regular';
      const full = sub.toLowerCase() === 'regular' ? family : `${family} ${sub}`;
      patch('fullName', full);
      repairs.push(`added missing 'fullName' → "${full}"`);
    }
    return repairs;
  }

  /* ── opentype.js error → plain English ── */
  function translateParseError(msg: string): string {
    if (/unsupported opentype signature/i.test(msg))
      return 'Unrecognised font format — file signature is not TTF, OTF, or WOFF.';
    if (/cmap/i.test(msg))
      return `Corrupted 'cmap' table (character-to-glyph mapping): ${msg}`;
    if (/checksum/i.test(msg))
      return `Table checksum mismatch: ${msg}. The file may have been partially overwritten.`;
    if (/end of data/i.test(msg) || /unexpected end/i.test(msg))
      return 'File is truncated — data ends before the font is fully described.';
    if (/name table/i.test(msg))
      return `Corrupted 'name' table (font metadata): ${msg}`;
    return msg;
  }

  /* ── Diagnostic display ── */
  function showDiag(issues: string[], warnings: string[], repairs: string[]) {
    const el = document.getElementById('fontDiag')!;
    if (!issues.length && !warnings.length && !repairs.length) {
      el.classList.add('hidden');
      return;
    }

    const lines: string[] = [];
    if (issues.length) {
      lines.push('<strong class="block mb-1 text-rose-700">Structural problems detected:</strong>');
      lines.push(issues.map(s => `<span class="block text-rose-600">✕ ${esc(s)}</span>`).join(''));
    }
    if (warnings.length) {
      lines.push('<strong class="block mb-1 mt-1.5 text-amber-700">Warnings:</strong>');
      lines.push(warnings.map(s => `<span class="block text-amber-600">⚠ ${esc(s)}</span>`).join(''));
    }
    if (repairs.length) {
      lines.push('<strong class="block mb-1 mt-1.5 text-sky-700">Auto-repaired:</strong>');
      lines.push(repairs.map(s => `<span class="block text-sky-600">↺ ${esc(s)}</span>`).join(''));
    }

    const hasFatal = issues.length > 0;
    el.className = hasFatal
      ? 'mb-4 rounded-md border border-rose-200 bg-rose-50 px-3 py-2.5 text-xs leading-relaxed'
      : repairs.length
        ? 'mb-4 rounded-md border border-sky-200 bg-sky-50 px-3 py-2.5 text-xs leading-relaxed'
        : 'mb-4 rounded-md border border-amber-200 bg-amber-50 px-3 py-2.5 text-xs leading-relaxed';
    el.innerHTML = lines.join('');
    el.classList.remove('hidden');
  }

  function esc(s: string): string {
    return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  let fontFile: File | null = null;
  let fontAB: ArrayBuffer | null = null;

  function fmtBytes(b: number): string {
    if (b < 1024) return b + ' B';
    if (b < 1048576) return (b / 1024).toFixed(1) + ' KB';
    return (b / 1048576).toFixed(2) + ' MB';
  }
  function baseName(name: string): string { return name.replace(/\.[^.]+$/, ''); }
  function extOf(name: string): string { return (name.split('.').pop() ?? '').toLowerCase(); }

  function showStatus(msg: string, type: 'ok' | 'err' | 'info') {
    const el = document.getElementById('fontStatus')!;
    el.textContent = msg;
    el.className = type === 'ok'
      ? 'text-center text-sm text-emerald-600'
      : type === 'err'
        ? 'text-center text-sm text-rose-500'
        : 'text-center text-sm text-slate-500';
    el.classList.remove('hidden');
  }

  function setProgress(pct: number) {
    const bar = document.getElementById('fontPBar')!;
    const fill = document.getElementById('fontPFill')!;
    if (pct > 0) { bar.classList.remove('hidden'); fill.style.width = pct + '%'; }
    else { bar.classList.add('hidden'); fill.style.width = '0%'; }
  }

  /* ── WOFF unwrapper (extracts raw sfnt from WOFF container) ── */
  async function zlibDecompress(data: Uint8Array): Promise<Uint8Array> {
    const ds = new DecompressionStream('deflate');
    const writer = ds.writable.getWriter();
    const reader = ds.readable.getReader();
    writer.write(data);
    writer.close();
    const chunks: Uint8Array[] = [];
    while (true) {
      const { value, done } = await reader.read();
      if (done) break;
      if (value) chunks.push(value);
    }
    const total = chunks.reduce((a, c) => a + c.length, 0);
    const out = new Uint8Array(total);
    let pos = 0;
    for (const c of chunks) { out.set(c, pos); pos += c.length; }
    return out;
  }

  async function unwrapWOFF(woffBuf: ArrayBuffer): Promise<ArrayBuffer> {
    const dv = new DataView(woffBuf);
    const wu8 = new Uint8Array(woffBuf);
    const sfVersion = dv.getUint32(4);   // sfnt flavor ('true', OTTO, 0x00010000…)
    const numTables = dv.getUint16(12);

    // WOFF table directory starts at byte 44.
    // Entry: tag(4) offset(4) compLength(4) origLength(4) origChecksum(4)
    const tables: { tag: string; checksum: number; data: Uint8Array }[] = [];
    for (let i = 0; i < numTables; i++) {
      const o = 44 + i * 20;
      const tag = String.fromCharCode(
        dv.getUint8(o), dv.getUint8(o+1), dv.getUint8(o+2), dv.getUint8(o+3)
      );
      const offset     = dv.getUint32(o + 4);
      const compLength = dv.getUint32(o + 8);
      const origLength = dv.getUint32(o + 12);
      const checksum   = dv.getUint32(o + 16);
      const raw = wu8.subarray(offset, offset + compLength);
      const data = compLength < origLength ? await zlibDecompress(raw) : raw;
      tables.push({ tag, checksum, data });
    }

    // Build sfnt binary header fields
    const n = numTables;
    let pow2 = 1; while (pow2 * 2 <= n) pow2 *= 2;
    const searchRange    = pow2 * 16;
    const entrySelector  = Math.log2(pow2);
    const rangeShift     = n * 16 - searchRange;

    // Calculate table offsets (4-byte aligned)
    const dirEnd = 12 + n * 16;
    let dataPos = dirEnd;
    const sfntOffsets = tables.map(t => {
      const o = dataPos; dataPos += (t.data.length + 3) & ~3; return o;
    });

    const sfnt = new ArrayBuffer(dataPos);
    const sdv = new DataView(sfnt);
    const su8 = new Uint8Array(sfnt);

    sdv.setUint32(0, sfVersion);
    sdv.setUint16(4, n);
    sdv.setUint16(6, searchRange);
    sdv.setUint16(8, entrySelector);
    sdv.setUint16(10, rangeShift);

    tables.forEach((t, i) => {
      const d = 12 + i * 16;
      for (let c = 0; c < 4; c++) sdv.setUint8(d + c, t.tag.charCodeAt(c));
      sdv.setUint32(d + 4, t.checksum);
      sdv.setUint32(d + 8, sfntOffsets[i]);
      sdv.setUint32(d + 12, t.data.length);
      su8.set(t.data, sfntOffsets[i]);
    });
    return sfnt;
  }

  /* ── WOFF builder (wraps raw sfnt data) ── */
  function buildWOFF(sfntBuffer: ArrayBuffer): ArrayBuffer {
    const dv = new DataView(sfntBuffer), u8 = new Uint8Array(sfntBuffer);
    const n = dv.getUint16(4);
    const tables: { tag: string; cs: number; off: number; len: number }[] = [];
    for (let i = 0; i < n; i++) {
      const o = 12 + i * 16;
      tables.push({
        tag: String.fromCharCode(dv.getUint8(o), dv.getUint8(o+1), dv.getUint8(o+2), dv.getUint8(o+3)),
        cs: dv.getUint32(o+4), off: dv.getUint32(o+8), len: dv.getUint32(o+12)
      });
    }
    const hSz = 44 + n * 20;
    let td = 0;
    const tOff = tables.map(t => { const o = hSz + td; td += (t.len + 3) & ~3; return o; });
    const tot = hSz + td, out = new ArrayBuffer(tot), od = new DataView(out), ou = new Uint8Array(out);
    let p = 0;
    od.setUint32(p, 0x774F4646); p += 4;
    od.setUint32(p, dv.getUint32(0)); p += 4;
    od.setUint32(p, tot); p += 4;
    od.setUint16(p, n); p += 2; od.setUint16(p, 0); p += 2;
    od.setUint32(p, sfntBuffer.byteLength); p += 4;
    od.setUint16(p, 1); p += 2; od.setUint16(p, 0); p += 2;
    for (let i = 0; i < 5; i++) { od.setUint32(p, 0); p += 4; }
    tables.forEach((t, i) => {
      for (let c = 0; c < 4; c++) od.setUint8(p + c, t.tag.charCodeAt(c));
      p += 4; od.setUint32(p, tOff[i]); p += 4; od.setUint32(p, t.len); p += 4;
      od.setUint32(p, t.len); p += 4; od.setUint32(p, t.cs); p += 4;
    });
    tables.forEach((t, i) => ou.set(u8.subarray(t.off, t.off + t.len), tOff[i]));
    return out;
  }

  /* ── EOT builder ── */
  function buildEOT(sfntBuffer: ArrayBuffer): ArrayBuffer {
    const u8 = new Uint8Array(sfntBuffer);
    const sz = 82 + sfntBuffer.byteLength;
    const out = new ArrayBuffer(sz), dv = new DataView(out), ou = new Uint8Array(out);
    dv.setUint32(0, sz, true); dv.setUint32(4, sfntBuffer.byteLength, true);
    dv.setUint32(8, 0x00020001, true);
    for (let i = 12; i < 82; i += 4) dv.setUint32(i, 0, true);
    dv.setUint32(36, 400, true); dv.setUint16(42, 0x504C, true);
    ou.set(u8, 82);
    return out;
  }

  /* ── Drop zone ── */
  const zone = document.getElementById('fontDropZone')!;
  const fileInput = document.getElementById('fontFileInput') as HTMLInputElement;

  zone.addEventListener('click', () => fileInput.click());
  zone.addEventListener('keydown', (e: KeyboardEvent) => { if (e.key === 'Enter' || e.key === ' ') fileInput.click(); });
  zone.addEventListener('dragover', (e: DragEvent) => { e.preventDefault(); zone.classList.add('border-purple-400', 'bg-purple-50/50'); });
  zone.addEventListener('dragleave', () => zone.classList.remove('border-purple-400', 'bg-purple-50/50'));
  zone.addEventListener('drop', (e: DragEvent) => {
    e.preventDefault(); zone.classList.remove('border-purple-400', 'bg-purple-50/50');
    const file = e.dataTransfer?.files[0];
    if (file) loadFont(file);
  });
  fileInput.addEventListener('change', () => { if (fileInput.files?.[0]) loadFont(fileInput.files[0]); });

  function loadFont(file: File) {
    fontFile = file; fontAB = null;
    const infoEl = document.getElementById('fontFileInfo')!;
    infoEl.textContent = `${file.name} · ${fmtBytes(file.size)}`;
    infoEl.classList.remove('hidden');
    document.getElementById('fontDiag')!.classList.add('hidden');
    showStatus(`Loaded: ${file.name}`, 'info');

    const reader = new FileReader();
    reader.onload = (ev) => {
      fontAB = ev.target!.result as ArrayBuffer;
      // Run structural check immediately for sfnt-flavoured files (TTF/OTF).
      // WOFF/WOFF2 have their own container — we only inspect the inner sfnt
      // during conversion where we have the decoded bytes.
      const magic = new DataView(fontAB).getUint32(0);
      const isSfntDirect = magic === 0x00010000 || magic === 0x4F54544F
        || magic === 0x74727565 || magic === 0x74797031;
      if (isSfntDirect) {
        const { issues, warnings } = inspectSfnt(fontAB);
        showDiag(issues, warnings, []);
      }
    };
    reader.readAsArrayBuffer(file);

    (document.getElementById('fontConvertBtn') as HTMLButtonElement).disabled = false;
    document.getElementById('fontControls')!.style.display = 'flex';
    document.getElementById('fontControls')!.classList.remove('hidden');
  }

  /* ── Convert ── */
  document.getElementById('fontConvertBtn')!.addEventListener('click', async () => {
    if (!fontFile || !fontAB) return;
    const to = (document.getElementById('fontTo') as HTMLSelectElement).value;
    const btn = document.getElementById('fontConvertBtn') as HTMLButtonElement;
    btn.disabled = true;
    try {
      setProgress(20);
      showStatus('Parsing…', 'info');

      let parseAB = fontAB;
      const isWoff2Input = extOf(fontFile.name) === 'woff2'
        || new DataView(fontAB).getUint32(0) === 0x774F4632; // 'wOF2'
      if (isWoff2Input) {
        showStatus('Decompressing WOFF2…', 'info');
        try {
          const ttfBytes = await decompressWOFF2(new Uint8Array(fontAB));
          parseAB = ttfBytes.buffer.slice(ttfBytes.byteOffset, ttfBytes.byteOffset + ttfBytes.byteLength);
        } catch {
          throw new Error('Failed to decompress WOFF2 file.');
        }
      }

      let font: any;
      try { font = opentype.parse(parseAB); }
      catch (e: any) {
        // Run structural inspection to give a specific diagnosis if possible.
        const { issues, warnings } = inspectSfnt(parseAB);
        if (issues.length) showDiag(issues, warnings, []);
        throw new Error(translateParseError(e?.message ?? 'Unknown parse error'));
      }

      setProgress(55);
      const base = baseName(fontFile.name);
      let buf: ArrayBuffer;

      const repairs = repairNameRecords(font, base);
      const sfnt = font.toArrayBuffer();

      if (to === 'ttf' || to === 'otf') {
        buf = sfnt;
      } else if (to === 'woff') {
        buf = buildWOFF(sfnt);
      } else if (to === 'woff2') {
        showStatus('Encoding WOFF2…', 'info');
        try {
          // Always use the original source bytes rather than toArrayBuffer() output.
          // opentype.js re-serialization can produce data that makes wawoff2 hang,
          // especially for CFF/OTF and WOFF-derived fonts.
          // WOFF needs its container stripped first; TTF/OTF/WOFF2 bytes are raw sfnt.
          const isWoffInput = new DataView(fontAB).getUint32(0) === 0x774F4646; // 'wOFF'
          const sfntToCompress = isWoffInput ? await unwrapWOFF(fontAB) : parseAB;
          const woff2Bytes = await compressWOFF2(new Uint8Array(sfntToCompress));
          buf = woff2Bytes.buffer.slice(woff2Bytes.byteOffset, woff2Bytes.byteOffset + woff2Bytes.byteLength);
        } catch {
          throw new Error('Failed to encode WOFF2.');
        }
      } else if (to === 'eot') {
        buf = buildEOT(sfnt);
      } else {
        throw new Error('Unknown format.');
      }

      setProgress(95);
      const mimes: Record<string, string> = {
        ttf: 'font/truetype', otf: 'font/otf',
        woff: 'font/woff', woff2: 'font/woff2', eot: 'application/vnd.ms-fontobject',
      };
      dl(new Blob([buf], { type: mimes[to] ?? 'application/octet-stream' }), `${base}.${to}`);
      setProgress(100);
      showStatus(`✓ Downloaded as ${base}.${to}`, 'ok');
      if (repairs.length) showDiag([], [], repairs);
    } catch (e: any) {
      showStatus('✕ ' + e.message, 'err');
      setProgress(0);
    }
    setTimeout(() => setProgress(0), 1500);
    btn.disabled = false;
  });

  function dl(blob: Blob, name: string) {
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url; a.download = name;
    document.body.appendChild(a); a.click(); document.body.removeChild(a);
    setTimeout(() => URL.revokeObjectURL(url), 10_000);
  }

</script>
