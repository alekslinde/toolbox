---
interface Props {
  title: string;
  description: string;
  href: string;
  tags: string[];
  icon: string;
}

const { title, description, href, tags, icon } = Astro.props;
---

<a
  href={href}
  class="group flex flex-col rounded-md border border-slate-200 bg-white p-5 no-underline shadow-sm transition-all hover:-translate-y-0.5 hover:shadow-md"
>
  <div class="mb-3 flex items-center gap-3">
    <span class="rounded-md bg-purple-50 px-2.5 py-1 font-mono text-xs font-medium text-purple-600">
      {icon}
    </span>
    <span class="font-semibold text-slate-900 group-hover:text-purple-600 transition-colors">
      {title}
    </span>
  </div>
  <p class="mb-4 flex-1 text-sm leading-relaxed text-slate-500">{description}</p>
  <div class="flex flex-wrap gap-1.5" aria-hidden="true">
    {tags.map((tag) => (
      <span class="rounded-full bg-slate-100 px-2.5 py-0.5 text-xs text-slate-500">{tag}</span>
    ))}
  </div>
</a>
